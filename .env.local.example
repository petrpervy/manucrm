# ── Supabase ──────────────────────────────────────────────────────────────────
# supabase.com → your project → Settings → Database → Connection String → URI
#
# For LOCAL dev: use the direct connection string (port 5432)
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# For VERCEL (production): use the Transaction pooler (port 6543)
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Rename this file to .env.local and paste your URL below:

DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
